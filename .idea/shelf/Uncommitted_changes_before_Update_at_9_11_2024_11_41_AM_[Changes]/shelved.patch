<+><html>\r\n<head>\r\n<title>stories.TC_005_SCC</title>\r\n<style type=\"text/css\" media=\"all\">\r\n@import url( \"./style/jbehave-core.css\" );\r\n</style>\r\n</head>\r\n<body>\r\n<div class=\"story\">\r\n<h1>&#65279;</h1>\r\n<div class=\"path\">stories/TC_005_SCC.story</div>\r\n<div class=\"scenario\">\r\n<h2>Scenario: TC_005_SCC_001 SCC Create Outgoing</h2>\r\n<div class=\"step successful\">Given  I navigate to 'http://172.16.30.82:808/Diwan_Enduser/login.aspx'</div>\r\n<div class=\"step successful\">And  I login as 'Sup-dew-1' with password 's'</div>\r\n<div class=\"step successful\">And  I click on 'Add Process Button'</div>\r\n<div class=\"step successful\">And  I click on 'Outgoing Button'</div>\r\n<div class=\"step successful\">When  Set 'Subject Field' value to 'random'</div>\r\n<div class=\"step successful\">And  I select '&#1593; | &#1605;&#1583;&#1610;&#1585; / &#1593;&#1591;&#1608;&#1601;&#1577; &#1575;&#1604;&#1605;&#1583;&#1610;&#1585; &#1575;&#1604;&#1593;&#1575;&#1605;' from the 'General Manager Office Outgoing SCC' combo box</div>\r\n<div class=\"step successful\">And  I select '1' from the 'File Name SCC' combo box</div>\r\n<div class=\"step successful\">And  Set 'File Subject SCC' value to 'random'</div>\r\n<div class=\"step successful\">And  Select '&#1575;&#1582;&#1585;&#1609;' value from 'Receiver Name Outgoing SCC' dropdown list</div>\r\n<div class=\"step successful\">And  I select '3496 | &#1571;&#1582;&#1585;&#1609;' from the 'Sub Receiver Name Outgoing SCC' combo box</div>\r\n<div class=\"step ignorable\">!-- And  I click on 'Save Draft Button'</div>\r\n<div class=\"step successful\">And  I click on 'Save Button'</div>\r\n<div class=\"step successful\">And  I get text from 'Subject Field' and save it as 'SubjectText'</div>\r\n<div class=\"step successful\">And  I get value from 'Outgoing Get Serial Number' and save it as 'OutgoingSerialNumberValue'</div>\r\n<div class=\"step successful\">And  I wait for '3' sec</div>\r\n<div class=\"step successful\">And  I click on 'Direction Tab'</div>\r\n<div class=\"step successful\">And  I click on 'Add Button'</div>\r\n<div class=\"step successful\">And  I wait for '4' sec</div>\r\n<div class=\"step successful\">And  I click on 'Close Notification Button'</div>\r\n<div class=\"step successful\">And  Verify 'Outgoing User Name Directed To1 SCC' equals '&#1585;&#1574;&#1610;&#1587; &#1588;&#1593;&#1576;&#1577; &#1575;&#1604;&#1578;&#1586;&#1608;&#1610;&#1583;' text</div>\r\n<div class=\"step successful\">And  I click on 'Direction Button'</div>\r\n<div class=\"step successful\">And  I wait for '10' sec</div>\r\n<div class=\"step successful\">And  I hover and click on 'All Task Header Button'</div>\r\n<div class=\"step successful\">And  I click on 'My Processes List Header Button'</div>\r\n<div class=\"step successful\">And  Verify 'Process Status' equals '&#1578;&#1605;&#1578; &#1575;&#1604;&#1593;&#1605;&#1604;&#1610;&#1577; &#1576;&#1606;&#1580;&#1575;&#1581;' text</div>\r\n<div class=\"step successful\">Then  I click on 'logout Button'</div>\r\n<div class=\"step successful\">And  Verify 'login Button' is present</div>\r\n<div class=\"step successful\">And  I login as 'supply-1' with password 's'</div>\r\n<div class=\"step ignorable\">!-- TEST</div>\r\n<div class=\"step ignorable\">!-- recheck this part that the xpath or css are the same as UOP</div>\r\n<div class=\"step successful\">And  I click on 'Tasks To View'</div>\r\n<div class=\"step ignorable\">!-- And  I click on 'Tasks To View Date'</div>\r\n<div class=\"step ignorable\">!-- And  I click on 'Tasks To View Date'</div>\r\n<div class=\"step failed\">And  Verify text of 'Tasks To View First Subject Text SCC' equals saved value 'SubjectText' <span class=\"keyword failed\">(FAILED)</span><br/><span class=\"message failed\">java.lang.Exception: Assertion failed: expected 'Auto1995506318191400', but was 'Auto1990233005492900'</span><br/><a color=\"black\" target=\"jb_scn_shot\" href=\"../screenshots/failed-scenario-0c67dd7a-4152-439d-86c0-a4c5912c4c93.png\"><img src=\"images/failing_screenshot.png\" alt=\"failing screenshot\"/></a></div>\r\n<div class=\"step notPerformed\">And  I click on 'Task List View Process Button' <span class=\"keyword notPerformed\">(NOT PERFORMED)</span></div>\r\n<div class=\"step notPerformed\">And  Verify text of 'Subject Field' equals saved value 'SubjectText' <span class=\"keyword notPerformed\">(NOT PERFORMED)</span></div>\r\n<div class=\"step notPerformed\">And  Verify value of 'Outgoing Get Serial Number' equals saved value 'OutgoingSerialNumberValue' <span class=\"keyword notPerformed\">(NOT PERFORMED)</span></div>\r\n<div class=\"step notPerformed\">And  I click on 'Direction Tab' <span class=\"keyword notPerformed\">(NOT PERFORMED)</span></div>\r\n<div class=\"step notPerformed\">And  I click on 'View Button' <span class=\"keyword notPerformed\">(NOT PERFORMED)</span></div>\r\n<div class=\"step notPerformed\">And  I wait for '3' sec <span class=\"keyword notPerformed\">(NOT PERFORMED)</span></div>\r\n<div class=\"step notPerformed\">And  I click on 'Completed Tasks' <span class=\"keyword notPerformed\">(NOT PERFORMED)</span></div>\r\n<div class=\"step notPerformed\">And  Verify text of 'Completed Tasks First Subject Text' equals saved value 'SubjectText' <span class=\"keyword notPerformed\">(NOT PERFORMED)</span></div>\r\n<div class=\"step notPerformed\">And  I click on 'logout Button' <span class=\"keyword notPerformed\">(NOT PERFORMED)</span></div>\r\n<div class=\"step notPerformed\">And  Verify 'login Button' is present <span class=\"keyword notPerformed\">(NOT PERFORMED)</span></div>\r\n<pre class=\"failure\">java.lang.Exception: Assertion failed: expected 'Auto1995506318191400', but was 'Auto1990233005492900'\r\n\tat com.automation.steps.CustomSteps.assertElementTextEqualsSavedValue(CustomSteps.java:70)\r\n\tat java.base/jdk.internal.reflect.DirectMethodHandleAccessor.invoke(DirectMethodHandleAccessor.java:103)\r\n\tat java.base/java.lang.reflect.Method.invoke(Method.java:580)\r\n\tat org.jbehave.core.steps.StepCreator$ParametrisedStep.perform(StepCreator.java:599)\r\n\tat org.jbehave.core.embedder.PerformableTree$FineSoFar.run(PerformableTree.java:340)\r\n...</pre>\r\n</div>\r\n</div>\r\n\r\n</body>\r\n<!--  SyntaxHighlighter resources:  should be included at end of body -->\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"./style/sh-3.0.83/shCore.css\"/>\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"./style/sh-3.0.83/shThemeRDark.css\"/>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shCore.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushBash.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushCss.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushDiff.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushGroovy.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushJava.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushJScript.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushPlain.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushPython.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushRuby.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushScala.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushXml.js\"></script>\r\n<script language=\"javascript\" src=\"./js/shBrushBdd.js\"></script>\r\n<script type=\"text/javascript\">\r\n    SyntaxHighlighter.defaults['gutter'] = false;\r\n    SyntaxHighlighter.defaults['toolbar'] = false;    \r\n    SyntaxHighlighter.all();\r\n</script>\r\n</html>\r\n
