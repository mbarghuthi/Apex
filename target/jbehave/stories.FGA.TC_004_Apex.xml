<step outcome="successful">And [Input] I click on &apos;FGASideMenu&apos;</step>
<step outcome="successful">And [Input] I click on &apos;TravelSetupSideMenu&apos;</step>
<step outcome="successful">And [Input] I click on &apos;TravelCalculationPricesSideMenu&apos;</step>
